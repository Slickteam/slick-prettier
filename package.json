{
  "name": "@slickteam/prettier",
  "version": "2.0.2",
  "description": "Prettier configuration for slickteam's project",
  "type": "module",
  "keywords": [
    "Slickteam",
    "Prettier"
  ],
  "license": "MIT",
  "author": {
    "name": "Ronan MOREL",
    "email": "ronan.morel@slickteam.fr",
    "url": "https://slickteam.fr"
  },
  "maintainers": [
    {
      "email": "ronan.morel@slickteam.fr",
      "name": "Ronan MOREL",
      "url": "https://slickteam.fr"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Slickteam/slick-prettier.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "index.js",
  "bin": {
    "slick-prettier": "./bin/slick-prettier.js"
  },
  "files": [
    "./index.js",
    "./bin",
    "./.prettierignore",
    "./.prettierrc"
  ],
  "scripts": {
    "prettier": "node bin/slick-prettier.js --cache --check .",
    "prettier:fix": "node bin/slick-prettier.js --cache --write ."
  },
  "dependencies": {
    "prettier": "^3.8.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2"
  },
  "packageManager": "pnpm@10.28.2"
}
